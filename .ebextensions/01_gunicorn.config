container_commands:
  01_kill_default_gunicorn:
    command: |
      # Kill any existing gunicorn processes
      pkill -f gunicorn || true
      
  02_create_gunicorn_config:
    command: |
      cat > /opt/elasticbeanstalk/config/private/gunicorn.config << EOF
      workers = 1
      threads = 2
      timeout = 300
      max_requests = 1000
      worker_class = gthread
      graceful_timeout = 30
      keepalive = 5
      EOF
      
  03_restart_web_service:
    command: |
      systemctl restart web.service || true

option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: pet_store.wsgi:application
    
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    StaticFiles: /static/=static/