{"filter":false,"title":"gunicorn.config","tooltip":"/.ebextensions/gunicorn.config","undoManager":{"mark":3,"position":3,"stack":[[{"start":{"row":0,"column":0},"end":{"row":41,"column":41},"action":"insert","lines":["option_settings:","  aws:elasticbeanstalk:container:python:","    WSGIPath: your_project_name.wsgi:application","    ","  aws:elasticbeanstalk:environment:proxy:staticfiles:","    StaticFiles: /static/=static/","","files:","  \"/opt/elasticbeanstalk/hooks/appdeploy/pre/00_set_gunicorn_workers.sh\":","    mode: \"000755\"","    owner: root","    group: root","    content: |","      #!/bin/bash","      # Calculate optimal workers for t2.micro (1GB RAM)","      # Use only 2 workers to conserve memory","      export GUNICORN_WORKERS=2","      export GUNICORN_THREADS=2","      export GUNICORN_TIMEOUT=300","      ","      # Write gunicorn config","      cat > /opt/elasticbeanstalk/config/private/gunicorn.config << EOF","      workers = 2","      threads = 2","      timeout = 300","      max_requests = 1000","      max_requests_jitter = 50","      graceful_timeout = 30","      keepalive = 5","      EOF","","  \"/opt/elasticbeanstalk/hooks/appdeploy/pre/01_set_gunicorn_env.sh\":","    mode: \"000755\"","    owner: root","    group: root","    content: |","      #!/bin/bash","      # Set Gunicorn environment variables","      echo \"export GUNICORN_WORKERS=2\" >> /etc/profile.d/gunicorn.sh","      echo \"export GUNICORN_THREADS=2\" >> /etc/profile.d/gunicorn.sh","      echo \"export GUNICORN_TIMEOUT=300\" >> /etc/profile.d/gunicorn.sh","      chmod +x /etc/profile.d/gunicorn.sh"],"id":1}],[{"start":{"row":2,"column":14},"end":{"row":2,"column":31},"action":"remove","lines":["your_project_name"],"id":2}],[{"start":{"row":2,"column":14},"end":{"row":2,"column":15},"action":"insert","lines":["p"],"id":3},{"start":{"row":2,"column":15},"end":{"row":2,"column":16},"action":"insert","lines":["e"]},{"start":{"row":2,"column":16},"end":{"row":2,"column":17},"action":"